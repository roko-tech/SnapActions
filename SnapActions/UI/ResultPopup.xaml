<Window x:Class="SnapActions.UI.ResultPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MaxWidth="450" MaxHeight="350">

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="10" Padding="12"
            MinWidth="200" MinHeight="60">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="4" Color="#000000"/>
        </Border.Effect>
        <StackPanel>
            <DockPanel Margin="0,0,0,8">
                <TextBlock x:Name="TitleText" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="X" Width="20" Height="20" FontSize="10"
                        Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                        BorderThickness="0" Click="Close_Click" Cursor="Hand"/>
            </DockPanel>

            <TextBlock x:Name="LoadingText" Text="Loading..." FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}" Visibility="Visible"/>

            <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="ResultText" FontSize="13" TextWrapping="Wrap"
                           Foreground="{StaticResource TextBrush}" Visibility="Collapsed"/>
            </ScrollViewer>

            <Button x:Name="CopyButton" Content="Copy" Visibility="Collapsed"
                    HorizontalAlignment="Left" Margin="0,8,0,0" Padding="12,4"
                    Background="{StaticResource SurfaceBrush}"
                    Foreground="{StaticResource TextBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    Click="Copy_Click" Cursor="Hand"/>
        </StackPanel>
    </Border>
</Window>
