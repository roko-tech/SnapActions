<Window x:Class="SnapActions.UI.ToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowActivated="False"
        Opacity="0">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.1">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="4" To="0" Duration="0:0:0.1">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.06"/>
        </Storyboard>
    </Window.Resources>

    <!-- Grid separates the toolbar from the popup so popup can't affect toolbar layout -->
    <Grid>
        <Border x:Name="MainBorder"
                Background="{StaticResource BackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="4" MaxWidth="600"
                VerticalAlignment="Top">
            <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="4" Color="#000000"/>
            </Border.Effect>

            <StackPanel Orientation="Vertical">
                <Border x:Name="TypeBadge" Visibility="Collapsed"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="4" Padding="6,2" Margin="2,2,2,4"
                        HorizontalAlignment="Left">
                    <TextBlock x:Name="TypeLabel" FontSize="10"
                               Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                </Border>

                <StackPanel x:Name="MainToolbar" Orientation="Horizontal">
                    <Button x:Name="CopyButton" Style="{StaticResource ActionButtonStyle}"
                            ToolTip="Copy" Click="CopyButton_Click">
                        <Path Data="{StaticResource IconCopy}" Fill="{StaticResource TextBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>

                    <Button x:Name="PasteButton" Style="{StaticResource ActionButtonStyle}"
                            ToolTip="Paste" Click="PasteButton_Click" Visibility="Collapsed"
                            MouseEnter="PasteButton_MouseEnter">
                        <TextBlock Text="V" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </Button>

                    <Border x:Name="ContextSeparator" Style="{StaticResource ToolbarSeparator}" Visibility="Collapsed"/>
                    <StackPanel x:Name="ContextActionsPanel" Orientation="Horizontal"/>

                    <!-- Pinned actions (user-selected favorites) -->
                    <Border x:Name="PinnedSeparator" Style="{StaticResource ToolbarSeparator}" Visibility="Collapsed"/>
                    <StackPanel x:Name="PinnedActionsPanel" Orientation="Horizontal"/>

                    <Border x:Name="TransformSeparator" Style="{StaticResource ToolbarSeparator}"/>
                    <Button x:Name="TransformButton" Style="{StaticResource CategoryButtonStyle}"
                            Content="Aa" Click="TransformButton_Click" ToolTip="Text Transforms"/>
                    <Button x:Name="EncodeButton" Style="{StaticResource CategoryButtonStyle}"
                            Content="&lt;/&gt;" Click="EncodeButton_Click" ToolTip="Encode/Decode"/>
                    <Border x:Name="SearchSeparator" Style="{StaticResource ToolbarSeparator}"/>
                    <Button x:Name="SearchButton" Style="{StaticResource CategoryButtonStyle}"
                            Click="SearchButton_Click" ToolTip="Search">
                        <Path Data="{StaticResource IconSearch}" Fill="{StaticResource TextSecondaryBrush}"
                              Width="14" Height="14" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Popup is outside the Border so opening it cannot affect toolbar layout/size -->
        <Popup x:Name="SubMenuPopup" StaysOpen="True" AllowsTransparency="True"
               PopupAnimation="Fade" Placement="Bottom" PlacementTarget="{Binding ElementName=MainBorder}">
            <Border Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="4"
                    MaxWidth="420" MaxHeight="400">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="3"/>
                </Border.Effect>
                <StackPanel>
                    <DockPanel Margin="4,2,4,4">
                        <TextBlock x:Name="SubMenuTitle" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="GearButton" Style="{StaticResource ActionButtonStyle}"
                                DockPanel.Dock="Right" Width="24" Height="24"
                                ToolTip="Toggle actions" Click="GearButton_Click">
                            <Path Data="{StaticResource IconSettings}"
                                  Fill="{StaticResource TextSecondaryBrush}"
                                  Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                    </DockPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="260">
                        <WrapPanel x:Name="SubMenuPanel" Orientation="Horizontal" MaxWidth="400"/>
                    </ScrollViewer>
                    <Border x:Name="PreviewBorder"
                            Background="{StaticResource SurfaceBrush}"
                            CornerRadius="4" Padding="8,6" Margin="4,4,4,2"
                            Height="32">
                        <TextBlock x:Name="PreviewText" FontSize="12" Opacity="0"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="Consolas" TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
